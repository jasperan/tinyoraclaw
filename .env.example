# TinyOraClaw .env example
#
# Quick start:
# 1) Copy this file to `.env`
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.

# ── LLM provider keys ─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Channel tokens ────────────────────────────────────────────
# DISCORD_BOT_TOKEN=...
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# ── TinyAGI API server ────────────────────────────────────────
# TINYAGI_API_PORT=3777

# ── TinyOraClaw sidecar wiring ────────────────────────────────
# This URL is the switch that enables Oracle-backed queue persistence.
TINYORACLAW_SERVICE_URL=http://localhost:8100
# TINYORACLAW_SERVICE_TOKEN=your-sidecar-bearer-token
# TINYORACLAW_SERVICE_PORT=8100

# ── Oracle AI Database (local FreePDB) ───────────────────────
ORACLE_MODE=freepdb
ORACLE_USER=tinyoraclaw
ORACLE_PASSWORD=TinyOraClaw2026
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREEPDB1
# ORACLE_POOL_MIN=2
# ORACLE_POOL_MAX=10

# ── Oracle Autonomous Database (ADB, optional) ───────────────
# ORACLE_MODE=adb
# ORACLE_USER=ADMIN
# ORACLE_PASSWORD=Welcome12345*
# ORACLE_DSN=(description= (retry_count=20)...)
# ORACLE_WALLET_PATH=/path/to/wallet
# ORACLE_WALLET_PASSWORD=wallet-secret

# ── OCI Generative AI (optional LLM backend) ─────────────────
# OCI_PROFILE=DEFAULT
# OCI_REGION=us-chicago-1
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-ocid
# OCI_GENAI_MODEL=meta.llama-3.3-70b-instruct
# OCI_PROXY_PORT=9999
