# TinyOraClaw .env example
#
# Quick start:
# 1) Copy this file to `.env`
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.

# -----------------------------------------------------------------------------
# TinyClaw Configuration (upstream)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Channel tokens
# DISCORD_BOT_TOKEN=...
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# API server port (default 3777)
# TINYCLAW_API_PORT=3777

# API authentication token (strongly recommended — set to enable bearer token auth on API server)
# TINYCLAW_API_TOKEN=your-secret-token-here

# =============================================================================
# TinyOraClaw - Oracle AI Database Storage
# =============================================================================
# TinyOraClaw extends TinyClaw with persistent memory powered by Oracle AI
# Vector Search.  Choose ONE of two modes:
#
#   freepdb  – local Docker container (Oracle Database Free)
#   adb      – Oracle Autonomous Database on OCI (cloud)
#
# The sidecar handles all database ops; the LLM provider is configured above.

# Oracle Database Mode
# ORACLE_MODE=freepdb

# ---- Option A: FreePDB (local Docker) ----
# Spins up with `docker compose up oracle-db tinyoraclaw-service`
# ORACLE_USER=tinyoraclaw
# ORACLE_PASSWORD=TinyOraClaw2026
# ORACLE_HOST=localhost
# ORACLE_PORT=1521
# ORACLE_SERVICE=FREEPDB1

# ---- Option B: Autonomous Database (OCI Cloud) ----
# Wallet-less TLS connections (thin driver) – paste the full DSN descriptor.
# ORACLE_MODE=adb
# ORACLE_USER=ADMIN
# ORACLE_PASSWORD=Welcome12345*
# ORACLE_DSN=(description= (retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=adb.us-phoenix-1.oraclecloud.com))(connect_data=(service_name=g2f4dc3e5463897_mern_tpurgent.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))
#
# If your ADB requires a wallet (mTLS), also set:
# ORACLE_WALLET_PATH=/path/to/wallet
# ORACLE_WALLET_PASSWORD=wallet-secret

# Connection Pool
# ORACLE_POOL_MIN=2
# ORACLE_POOL_MAX=10

# In-database ONNX Embedding Model
# ORACLE_ONNX_MODEL=ALL_MINILM_L12_V2

# TinyOraClaw Sidecar Service
# TINYORACLAW_SERVICE_PORT=8100
# TINYORACLAW_SERVICE_TOKEN=          # Set to enable bearer token auth on sidecar API

# =============================================================================
# OCI Generative AI (Optional LLM Backend)
# =============================================================================
# Use OCI GenAI instead of/alongside Anthropic/OpenAI for LLM inference.
# Requires: pip install oci-openai && configured ~/.oci/config
# See oci-genai/README.md for full setup instructions.
#
# OCI_PROFILE=DEFAULT
# OCI_REGION=us-chicago-1
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-ocid
# OCI_GENAI_MODEL=meta.llama-3.3-70b-instruct
# OCI_PROXY_PORT=9999
